function [b] = bin(x)
  n = size(x,1) ;
  for i = 1:n
    v = x(i) ;
    if (v == 1) b(1) = b(1) + 1 ;
    if (v == 2) b(2) = b(2) + 1 ;
    if  (v == 3) b(3) = b(3) + 1 ;
  end
end

