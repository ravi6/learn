<!-- Modal Dialogue with For ColorSetting -->
<div class="modal" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Set Color</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
           <input type="range" min=0 max=255 value=0 step=1 class="slider" id="x">
           <input type="range" min=0 max=255 value=0 step=1 class="slider" id="y">
           <input type="range" min=0 max=255 value=0 step=1  class="slider" id="z">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
