
<!-- Modal Dialogue with For ColorSetting -->
<div class="modal-sm" tabindex="-1" role="dialog" id=dlgColor>
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header"> <h5 class="modal-title">Set Color</h5> </div>
      <div class="modal-body">
	   <div class=row> <input type="range" min=0 max=255 value=0 step=1 class="slider" id="x"> </div>
	   <div class=row> <input type="range" min=0 max=255 value=0 step=1 class="slider" id="y"> </div>
	   <div class=row> <input type="range" min=0 max=255 value=0 step=1  class="slider" id="z"> </div>
      </div>
      <div class="modal-footer"> <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button> </div>
    </div>
  </div>
</div>
<!----   End Color Setup Dialogue -->
